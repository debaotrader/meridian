{
  "name": "mission-control",
  "version": "1.5.3",
  "private": true,
  "scripts": {
    "dev": "next dev --turbo -p ${PORT:-4000}",
    "build": "next build",
    "start": "next start -p ${PORT:-4000}",
    "lint": "next lint",
    "test": "mkdir -p .tmp && rm -f .tmp/mission-control-test.db* && NODE_ENV=test DATABASE_PATH=.tmp/mission-control-test.db tsx --test src/**/*.test.ts",
    "db:seed": "tsx src/lib/db/seed.ts",
    "db:backup": "sqlite3 mission-control.db 'PRAGMA wal_checkpoint(TRUNCATE);' && cp mission-control.db mission-control.db.backup && echo 'Backed up to mission-control.db.backup'",
    "db:restore": "cp mission-control.db.backup mission-control.db && echo 'Restored from backup'",
    "db:reset": "rm -f mission-control.db mission-control.db-* && npm run db:seed"
  },
  "dependencies": {
    "@fontsource-variable/inter": "^5.2.8",
    "@hello-pangea/dnd": "^17.0.0",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.5.0",
    "@react-three/postprocessing": "^3.0.4",
    "@supabase/supabase-js": "^2.99.2",
    "@vercel/analytics": "^2.0.1",
    "better-sqlite3": "^12.6.2",
    "clsx": "^2.1.1",
    "css-tree": "^3.1.0",
    "date-fns": "^4.1.0",
    "framer-motion": "^12.38.0",
    "geist": "^1.7.0",
    "i18next": "^25.8.18",
    "immer": "^11.1.4",
    "lucide-react": "^0.468.0",
    "next": "^15.5.13",
    "playwright": "^1.58.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-i18next": "^16.5.8",
    "react-markdown": "^10.1.0",
    "recharts": "^3.8.0",
    "source-map-js": "^1.2.1",
    "tailwind-merge": "^3.5.0",
    "three": "^0.183.2",
    "uuid": "^11.0.4",
    "zod": "^4.3.6",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/css-tree": "^2.3.11",
    "@types/node": "^20.17.12",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/three": "^0.183.1",
    "@types/uuid": "^10.0.0",
    "autoprefixer": "^10.4.20",
    "eslint": "^8.57.0",
    "eslint-config-next": "14.2.21",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  },
  "license": "AGPL-3.0"
}
