# ============================================
# Meridian — Variáveis de Ambiente
# ============================================

# --- Gateway OpenClaw ---
NEXT_PUBLIC_OPENCLAW_GATEWAY_URL=ws://localhost:4001
NEXT_PUBLIC_OPENCLAW_API_KEY=your-api-key-here

# --- Backend ---
OPENCLAW_DB_PATH=./data/project.db
OPENCLAW_HMAC_SECRET=your-hmac-secret-here
OPENCLAW_API_TOKEN=your-bearer-token-here

# --- Segurança da API ---
# OBRIGATÓRIO em produção! Sem isso, a API roda sem autenticação (dev mode).
# Gerar com: openssl rand -hex 32
MC_API_TOKEN=your-mc-api-token-here

# --- Server ---
PORT=4000
NODE_ENV=development

# --- Módulo Vibe ---
NEXT_PUBLIC_OPENCLAWFICE_URL=http://localhost:3333

# --- Opcional ---
NEXT_PUBLIC_MOCK_GATEWAY=false

# --- Feature Flags ---
OPENCLAW_ENABLE_OFFICE_3D=1
OPENCLAW_ENABLE_VIBE=1
OPENCLAW_DEFAULT_THEME=dark
OPENCLAW_LOG_LEVEL=info
